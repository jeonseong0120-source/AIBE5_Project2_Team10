# application.yml.sample
spring:
  datasource:
    url: ${DB_URL}
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQLDialect
        default_batch_fetch_size: 100

  security:
    oauth2:
      client:
        registration:
          google:
            client-id: ${GOOGLE_CLIENT_ID}
            client-secret: ${GOOGLE_CLIENT_SECRET}
            scope:
              - email
              - profile

# ==========================================
# 보안 및 인증 설정 (JWT)
# ==========================================
jwt:
  # 운영 환경에서는 반드시 환경 변수로 주입하세요.
  secret: ${JWT_SECRET}
  expiration: ${JWT_EXPIRATION_MS:3600000}

app:
  # 벌크 데모 시드: APP_SEED_BULK_DEMO=true 시 기동 1회 삽입(DemoBulkSeedRunner)
  # 최초 실행 후 false로 전환!!
  # [벌크 데모 로그인] 이메일/비밀번호 로그인
  #   프리랜서: bulk-demo-freelancer-01@local.test ~ bulk-demo-freelancer-10@local.test
  #   클라이언트: bulk-demo-client-01@local.test ~ bulk-demo-client-10@local.test
  #   비밀번호(공통): BulkDemo1!
  #   재시드: 마커 계정이 있으면 앱 시드는 전체 스킵 → 전부 갈아엎으려면
  #   backend/scripts/clear_bulk_demo_seed.sql 후 재기동
  #   부분 수정만: 계정/공고 유지한 채 SQL 패치만 실행 가능
  #     예) backend/scripts/bulk_demo_portfolio_skills_only.sql
  #         backend/scripts/bulk_demo_patch_project_skills_max5.sql
  #         backend/scripts/gangnam_map_seed_freelancers.sql (강남 좌표 분산 프리랜서 10명, 단독)
  seed:
    bulk-demo: ${APP_SEED_BULK_DEMO:false}

  cors:
    allowed-origins:
      - ${APP_CORS_ALLOWED_ORIGINS:http://localhost:3000}
      - http://127.0.0.1:3000

  oauth2:
    redirect-uri: ${APP_OAUTH2_REDIRECT_URI:http://localhost:3000/oauth/redirect}
    error-uri: ${APP_OAUTH2_ERROR_URI:http://localhost:3000/login}

kakao:
  maps:
    api-key: ${KAKAO_MAPS_API_KEY}
    rest-api-key: ${KAKAO_REST_API_KEY}

cloudinary:
  cloud-name: ${CLOUDINARY_CLOUD_NAME}
  api-key: ${CLOUDINARY_API_KEY}
  api-secret: ${CLOUDINARY_API_SECRET}
  upload-folder: ${CLOUDINARY_UPLOAD_FOLDER:devnear}

# Google Gemini (임베딩 + 스킬 태그 NLP 추출)
gemini:
  api-key: ${GEMINI_API_KEY:}
  base-url: https://generativelanguage.googleapis.com/v1beta
  embedding-model: gemini-embedding-001
  # POST /skills/suggest 시 문서→스킬 매핑에 사용 (미설정 시 규칙 기반만 사용)
  generation-model: gemini-2.0-flash
